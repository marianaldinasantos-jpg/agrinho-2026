/* Custom Properties - Paleta de Cores e Variáveis */
:root {
    --bg-dark: #0a0f1d;       /* Preto/Azul Escuro Futurista */
    --surface-dark: #12192c;  /* Azul Metálico Escuro */
    --text-light: #ffffff;    /* Branco */
    --accent-blue: #00d2ff;   /* Azul Celeste */
    --accent-green: #39ff14;  /* Verde Neon / Campo Digital */
    --accent-gold: #ffd700;   /* Ouro / Inteligência */
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: var(--bg-dark);
    color: var(--text-light);
    line-height: 1.6;
}

/* Hero Section */
.hero {
    height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(135deg, var(--bg-dark) 20%, var(--surface-dark) 100%);
    border-bottom: 3px solid var(--accent-green);
    padding: 20px;
}

.hero-title {
    font-size: 3rem;
    color: var(--accent-blue);
    text-transform: uppercase;
    letter-spacing: 2px;
}

.hero-subtitle {
    margin: 20px 0;
    font-size: 1.2rem;
    color: var(--text-light);
}

.btn-hero {
    display: inline-block;
    padding: 12px 30px;
    background-color: transparent;
    color: var(--accent-gold);
    border: 2px solid var(--accent-gold);
    text-decoration: none;
    font-weight: bold;
    text-transform: uppercase;
    transition: all 0.3s ease;
}

.btn-hero:hover {
    background-color: var(--accent-gold);
    color: var(--bg-dark);
    box-shadow: 0 0 15px var(--accent-gold);
}

/* Layout Geral & Responsividade */
.main-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px;
}

/* Placeholders de Imagem */
.image-placeholder {
    background: #1a243d;
    border: 2px dashed var(--accent-blue);
    height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-blue);
    font-weight: bold;
    margin: 30px 0;
    border-radius: 8px;
}

/* Cards dos Benefícios */
.cards-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin: 40px 0;
}

.card {
    background-color: var(--surface-dark);
    padding: 25px;
    border-left: 4px solid var(--accent-green);
    border-radius: 4px;
}

.card h3 {
    color: var(--accent-green);
    margin-bottom: 10px;
}

/* Estilização Básica do Accordion */
.accordion-item {
    background-color: var(--surface-dark);
    margin-bottom: 10px;
    border-radius: 4px;
    overflow: hidden;
}

.accordion-header {
    width: 100%;
    background: none;
    border: none;
    padding: 20px;
    color: var(--text-light);
    text-align: left;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
    padding: 0 20px;
}

/* Classe utilitária que o JS vai controlar */
.accordion-item.active .accordion-body 
{padding: 0 20px 20px 20px;
}





























